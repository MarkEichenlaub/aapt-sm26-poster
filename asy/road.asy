unitsize(2cm);

draw(yscale(2)*((0,0)--(1,0){1,0}..(2,.5)..{1,-.25}(2.5,.2)--(3,.075){1,-.25}..(3.5,-.15){1,0}..{1,0}(4,0){1,0}--(4.5,0)));

dot((.5,0));
label("A",(.5,0),S);

dot((1.14,.055));
label("B",(1.14,.055),S);

dot((2,.5*2));
label("C",(2,.5*2),N);

dot((2.7,2*(.2-.25*.2)));
label("D",(2.7,2*(.2-.25*.2)),N);

dot((3.5,-.15*2));
label("E",(3.5,-.15*2),S);
